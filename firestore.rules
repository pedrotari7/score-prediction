rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{competition}/fixtures {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /{competition}/standings {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
