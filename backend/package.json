{
  "name": "backend",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "dev": "concurrently --kill-others \"tsc --watch --preserveWatchOutput\" \"pnpm firebase emulators:start --only functions\"",
    "shell": "pnpm build && pnpm firebase functions:shell",
    "start": "pnpm shell",
    "deploy": "pnpm firebase deploy --only functions",
    "login": "pnpm firebase login",
    "logs": "pnpm firebase functions:log",
    "firebase": "firebase",
    "test": "jest --config jest.config.ts --runInBand",
    "test:emulator": "firebase emulators:exec --only firestore,auth --project demo-test-project 'pnpm test'",
    "preinstall": "npx only-allow pnpm"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/backend/src/index.js",
  "dependencies": {
    "@google-cloud/functions-framework": "5.0.2",
    "axios": "1.16.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.2.5"
  },
  "devDependencies": {
    "@firebase/app-types": "0.9.5",
    "@stylistic/eslint-plugin-ts": "2.13.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "concurrently": "9.2.1",
    "eslint": "8.57.1",
    "eslint-config-google": "0.14.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "@types/jest": "29.5.14",
    "@types/supertest": "7.2.0",
    "firebase": "12.13.0",
    "firebase-functions-test": "3.5.0",
    "firebase-tools": "15.18.0",
    "jest": "29.7.0",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "license": "ISC",
  "private": true
}